# ============================================================
# WHITELABEL MULTI-DOMAIN CONFIGURATION
# ============================================================

# DOMAIN CONFIGURATION
# Specifies which domain configuration to load (fitness, business, etc.)
DOMAIN=fitness

# ============================================================
# BRANDING & THEMING
# ============================================================

BRAND_NAME=Fitness Tracker
BRAND_DESCRIPTION=Your personal fitness companion
BRAND_LOGO=/assets/fitness/logo.png
FAVICON_URL=/assets/fitness/favicon.ico

# Color Scheme (Hex colors)
PRIMARY_COLOR=#ff6b35
SECONDARY_COLOR=#004e89
ACCENT_COLOR=#f7b801
TEXT_COLOR=#1a1a1a
BG_COLOR=#ffffff

# Typography
FONT_FAMILY=Inter, system-ui, sans-serif

# ============================================================
# DATA SOURCE CONFIGURATION
# ============================================================

# Data source type: json, sql, or api
DATA_SOURCE_TYPE=json

# For JSON data source
DATA_SOURCE_FILE=./data/fitness_guides.json

# For SQL database
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fitness_db
# DB_USER=postgres
# DB_PASSWORD=password

# For REST API
# API_ENDPOINT=https://api.example.com/data
# API_KEY=your-api-key

# ============================================================
# LLM CONFIGURATION
# ============================================================

# LLM Provider: openai, claude, or ollama
LLM_PROVIDER=claude

# Model selection
LLM_MODEL=claude-3-sonnet-20240229

# API Keys
CLAUDE_API_KEY=your-claude-api-key
# OPENAI_API_KEY=your-openai-api-key
# OLLAMA_BASE_URL=http://localhost:11434

# LLM Behavior
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ============================================================
# FEATURE FLAGS
# ============================================================

# Voice Features
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true

# Content Features
ENABLE_VIDEO_SUPPORT=false
ENABLE_SOCIAL_SHARING=true
ENABLE_USER_ACCOUNTS=true
ENABLE_OFFLINE_MODE=false

# Platform Features
ENABLE_ANALYTICS=true
ENABLE_MULTILANGUAGE=true

# ============================================================
# BUSINESS LOGIC
# ============================================================

# Localization
CURRENCY=INR
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ta,te,hi,kn,ml

# Search & Results
MAX_SEARCH_RESULTS=5
RESULTS_PER_PAGE=10

# Content Categories (comma-separated)
CONTENT_CATEGORIES=Cardio,Strength,Flexibility,Nutrition,Recovery

# Audio/Voice
VOICE_SAMPLE_RATE=16000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=30

# Caching
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# API
CORS_ORIGIN=http://localhost:3000
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY_MS=1000

# ============================================================
# LOGGING
# ============================================================

LOG_LEVEL=info
LOG_FORMAT=text
ENABLE_FILE_LOGGING=false
LOG_DIRECTORY=./logs

# ============================================================
# OPTIONAL: DATABASE & CACHE
# ============================================================

# PostgreSQL
# DATABASE_URL=postgresql://postgres:password@localhost:5432/fitness_chat

# Redis
# REDIS_URL=redis://localhost:6379

# ============================================================
# OPTIONAL: VOICE SERVICES (Sarvam AI)
# ============================================================

# NEXT_PUBLIC_SARVAM_API_KEY=your-sarvam-api-key
