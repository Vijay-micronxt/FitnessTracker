# Frontend Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3002

# Voice and Multilingual Features
# These features are now configured on the backend via /config endpoint
# The frontend will fetch these settings automatically
# Set them in your backend .env file instead:
# - FEATURE_VOICE_INPUT=true/false
# - FEATURE_VOICE_OUTPUT=true/false
# - FEATURE_MULTILINGUAL=true/false
# - SUPPORTED_LANGUAGES=en,es,fr,hi,ta,te
