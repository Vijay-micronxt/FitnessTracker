# Sarvam AI Voice Integration Environment Variables

# Get your API key from: https://dashboard.sarvam.ai
# This key is used for both Speech-to-Text and Text-to-Speech APIs
NEXT_PUBLIC_SARVAM_API_KEY=your_sarvam_api_key_here

# Optional: Set default language for voice features (default: 'en')
# Supported: 'hi', 'en', 'ta', 'te', 'bn', 'gu', 'kn', 'ml', 'mr', 'pa', 'or', etc.
NEXT_PUBLIC_SARVAM_DEFAULT_LANGUAGE=en

# Optional: Set default voice for TTS (default: 'Shubh')
# Popular options: 'Shubh', 'Shreya', 'Manan', 'Ishita'
NEXT_PUBLIC_SARVAM_DEFAULT_VOICE=Shubh

# Optional: Backend API URL for chat
NEXT_PUBLIC_API_URL=http://localhost:3002
