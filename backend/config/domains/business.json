{
  "id": "business",
  "name": "Business Assistance",
  "description": "AI-powered business assistance with ERPNext integration",
  "version": "1.0.0",
  "environment": "production",

  "branding": {
    "brandName": "Business Assistance",
    "appName": "Business Operations Assistant",
    "brandLogo": "/logos/business-logo.png",
    "description": "Intelligent assistant for business operations",
    "primaryColor": "#1e40af",
    "secondaryColor": "#1e3a8a",
    "accentColor": "#3b82f6",
    "backgroundColor": "#f8fafc",
    "textColor": "#1f2937",
    "fontFamily": "Inter, system-ui, sans-serif"
  },

  "dataSource": {
    "type": "rest",
    "name": "ERPNext API",
    "endpoint": "https://your-erpnext-instance.com",
    "auth": {
      "type": "custom-header",
      "header": "Authorization",
      "tokenFormat": "token {api_key}:{api_secret}"
    },
    "cacheEnabled": true,
    "cacheTTL": 600,
    "description": "Connects to ERPNext for business operations data"
  },

  "features": {
    "voice": {
      "enabled": true,
      "input": true,
      "output": true,
      "languages": ["en", "hi", "ta"]
    },
    "chat": {
      "enabled": true,
      "maxMessageLength": 5000,
      "rateLimitPerMinute": 30
    },
    "localization": {
      "enabled": true,
      "defaultLanguage": "en",
      "supportedLanguages": ["en", "hi", "ta", "te"]
    },
    "dataExport": {
      "enabled": false,
      "formats": ["json", "csv"]
    },
    "advancedAnalytics": {
      "enabled": false
    }
  },

  "llm": {
    "provider": "claude",
    "model": "claude-haiku-4-5-20251001",
    "temperature": 0.7,
    "maxTokens": 2048,
    "systemPrompt": "You are a helpful business operations assistant integrated with ERPNext. You help users query and understand their business data. You can access information about customers, orders, invoices, payments, suppliers, and inventory. Always provide clear, structured responses and ask clarifying questions when needed."
  },

  "businessLogic": {
    "readOnlyMode": true,
    "allowedOperations": [
      "list_customers",
      "list_orders",
      "list_invoices",
      "list_payments",
      "list_items",
      "search_customers",
      "get_order_details",
      "check_stock"
    ],
    "defaultFilters": {
      "orders": {
        "status": ["!=", "Closed"]
      },
      "invoices": {
        "docstatus": 1
      }
    },
    "maxRecordsPerQuery": 100,
    "paginationLimit": 20
  },

  "erp": {
    "enabled": true,
    "integrationPoints": [
      "customer_data",
      "sales_orders",
      "invoices",
      "payments",
      "inventory",
      "suppliers",
      "projects"
    ],
    "timeoutMs": 30000,
    "retryCount": 3
  },

  "supportedLanguages": [
    {
      "code": "en",
      "name": "English",
      "direction": "ltr"
    },
    {
      "code": "hi",
      "name": "हिन्दी",
      "direction": "ltr"
    },
    {
      "code": "ta",
      "name": "தமிழ்",
      "direction": "ltr"
    },
    {
      "code": "te",
      "name": "తెలుగు",
      "direction": "ltr"
    }
  ],

  "themeVariant": "light",
  "customization": {
    "enableCustomCSS": false,
    "customCSSPath": "/styles/business-custom.css"
  },

  "security": {
    "requiresAuthentication": true,
    "sessionTimeout": 3600,
    "enableAuditLog": true,
    "dataEncryption": true
  },

  "metadata": {
    "createdAt": "2026-03-21T00:00:00Z",
    "updatedAt": "2026-03-21T00:00:00Z",
    "author": "System",
    "tags": ["business", "erp", "operations", "read-only"]
  }
}
