# EC2 Deployment Configuration Template
# Copy this file to .env and update values for your EC2 instance

# Server Configuration
PORT=3001
NODE_ENV=production

# ============================================
# DATABASE SETUP ON EC2
# ============================================
# Option 1: PostgreSQL on EC2 instance
# First, install PostgreSQL on EC2:
#   sudo apt update && sudo apt install postgresql postgresql-contrib -y
#   sudo -u postgres createdb fitness_chat
#   sudo -u postgres createuser ubuntu (set password)
DATABASE_URL=postgresql://ubuntu:your_password@localhost:5432/fitness_chat

# Option 2: AWS RDS (Recommended for production)
# Create RDS instance in AWS Console, then use:
# DATABASE_URL=postgresql://admin:password@fitness-db.xxxxx.us-east-1.rds.amazonaws.com:5432/fitness_chat

# ============================================
# REDIS SETUP ON EC2
# ============================================
# Option 1: Redis on EC2 instance
# First, install Redis on EC2:
#   sudo apt update && sudo apt install redis-server -y
#   sudo systemctl start redis-server
REDIS_URL=redis://localhost:6379

# Option 2: AWS ElastiCache (Recommended for production)
# REDIS_URL=redis://your-cluster.xxxxx.ng.0001.use1.cache.amazonaws.com:6379

# ============================================
# LLM CONFIGURATION
# ============================================
# Options: "openai", "claude", "ollama"
LLM_PROVIDER=claude

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Claude (Anthropic) Configuration
CLAUDE_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Ollama Configuration (for local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ============================================
# EMBEDDING CONFIGURATION
# ============================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai
# Note: Requires valid OPENAI_API_KEY above

# ============================================
# RATE LIMITING & CACHING
# ============================================
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=30

CACHE_TTL_QUERY=600
CACHE_TTL_EMBEDDING=3600
CACHE_TTL_RESPONSE=86400

# ============================================
# APPLICATION
# ============================================
LOG_LEVEL=info

# CORS_ORIGIN: Set to your EC2 IP or domain
# Example with IP: http://15.206.167.61:3000
# Example with domain: http://yourdomain.com:3000
CORS_ORIGIN=http://15.206.167.61:3000

# ============================================
# SETUP INSTRUCTIONS FOR EC2 UBUNTU
# ============================================
# 
# 1. UPDATE SYSTEM
#    sudo apt update && sudo apt upgrade -y
#
# 2. INSTALL NODE.JS
#    curl -fsSL https://deb.nodesource.com/setup_18.x | sudo -E bash -
#    sudo apt-get install -y nodejs
#
# 3. INSTALL POSTGRESQL
#    sudo apt install postgresql postgresql-contrib -y
#    sudo -u postgres createdb fitness_chat
#    sudo -u postgres psql
#    CREATE USER ubuntu WITH PASSWORD 'your_password';
#    ALTER ROLE ubuntu WITH CREATEDB;
#    GRANT ALL PRIVILEGES ON DATABASE fitness_chat TO ubuntu;
#    \q
#
# 4. INSTALL REDIS
#    sudo apt install redis-server -y
#    sudo systemctl enable redis-server
#    sudo systemctl start redis-server
#
# 5. CLONE & DEPLOY PROJECT
#    cd /home/ubuntu
#    git clone your-repo.git fitness-chat-app
#    cd fitness-chat-app
#    cp backend/.env.ec2.example backend/.env
#    # Edit .env with your configuration
#    ./start.sh
#
# 6. SECURITY GROUPS
#    Add inbound rules:
#    - Port 3000 (Frontend) - 0.0.0.0/0
#    - Port 3001 (Backend) - 0.0.0.0/0
#    - Port 22 (SSH) - Your IP
#
# 7. OPTIONAL: NGINX REVERSE PROXY + SSL
#    sudo apt install nginx -y
#    # Configure nginx config with SSL certificate
#    # Use Let's Encrypt for free SSL
